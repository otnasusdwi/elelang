    "paths": {
        "/admin/auctions": {
            "post": {
                "tags": [
                    "Admin - Auctions"
                ],
                "summary": "Create auction (admin)",
                "operationId": "db2e7cf71890ef870bd2a93db118a94b",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "commodity_id",
                                    "start_at",
                                    "end_at"
                                ],
                                "properties": {
                                    "commodity_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "start_at": {
                                        "type": "string",
                                        "example": "2026-02-25 12:00:00"
                                    },
                                    "end_at": {
                                        "type": "string",
                                        "example": "2026-02-25 12:30:00"
                                    },
                                    "timezone": {
                                        "type": "string",
                                        "example": "Asia/Makassar"
                                    },
                                    "anti_sniping_seconds": {
                                        "type": "integer",
                                        "example": 10
                                    },
                                    "extend_minutes": {
                                        "type": "integer",
                                        "example": 10
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Created"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "403": {
                        "description": "Forbidden"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
